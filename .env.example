# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
#
# Get a Gemini API key:
#   https://aistudio.google.com/apikey
#
# Required for direct Gemini routing through LiteLLM.
GEMINI_API_KEY=your-gemini-api-key-here

# Optional. Development fallback if direct LiteLLM-to-Gemini routing blocks.
# Sign up at https://openrouter.ai/. The OpenRouter smoke uses
# infra/litellm_openrouter_config.yaml and scripts/smoke_openrouter.py.
OPENROUTER_API_KEY=
