# Copy this file to `.env` and fill in your keys. `.env` is gitignored.
#
# Get a Gemini API key (free tier is generous, no credit card required):
#   https://aistudio.google.com/apikey
#
# Required for any LLM call (planner, narrator, the benign smoke-test case).
GEMINI_API_KEY=your-gemini-api-key-here

# Optional. Demo-day fallback if direct LiteLLM→Gemini routing blocks.
# Sign up at https://openrouter.ai/ — they route to Gemini (and many other
# models) via an OpenAI-compatible interface. Leave blank unless you want
# to enable the commented-out fallback route in infra/litellm_config.yaml.
# OPENROUTER_API_KEY=
